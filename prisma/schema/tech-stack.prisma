model TechStack {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  title        String        @unique
  logo         String
  type         String        @unique
  displayOrder Int           @default(0)
  tools        TechTool[]
  categoryId   String?       @db.ObjectId
  category     TechCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}
