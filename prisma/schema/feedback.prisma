model Feedback {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  sectionId       String?          @db.ObjectId
  review          String
  featured        Boolean
  feedbackSection FeedbackSection? @relation(fields: [sectionId], references: [id])
  author          String
  receivedAt      DateTime

  @@unique([author, sectionId, review, receivedAt])
}
