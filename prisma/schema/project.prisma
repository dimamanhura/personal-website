model Project {
  id               String                   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String                   @unique
  shortDescription String
  longDescription  String
  features         String[]
  startAt          DateTime
  endAt            DateTime?
  logo             String?
  position         String
  team             String[]
  featured         Boolean
  responsibilities String[]
  integrations     String[]
  stack            String[]
  technologies     ProjectTechnologySection
  achievements     ProjectAchievement[]
}
