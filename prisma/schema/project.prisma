model Project {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  name             String               @unique
  slug             String               @unique
  shortDescription String
  longDescription  String
  features         String[]
  startAt          DateTime
  endAt            DateTime?
  logo             String?
  position         String
  team             String[]
  featured         Boolean              @default(false)
  responsibilities String[]
  achievements     ProjectAchievement[]
  stackIds         String[]             @db.ObjectId
  stacks           TechStack[]          @relation(fields: [stackIds], references: [id])
  integrationIds   String[]             @db.ObjectId
  integrations     TechTool[]           @relation("ProjectIntegrations", fields: [integrationIds], references: [id])
  toolIds          String[]             @db.ObjectId
  tools            TechTool[]           @relation("ProjectTools", fields: [toolIds], references: [id])
}
